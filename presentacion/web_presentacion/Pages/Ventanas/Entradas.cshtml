@page
@model EntradasModel
@{
    ViewData["Title"] = "Entradas";
}
<center>
    <div>
        <form method="POST" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div align="left">
                <h3>Entradas</h3>
            </div>

            <div>
                <input type="submit"
                       value="Refrescar"
                       class="btn btn-secondary"
                       asp-page-handler="BtRefrescar" />
                <input type="submit"
                       value="Nuevo"
                       class="btn btn-secondary"
                       asp-page-handler="BtNuevo"
                       disabled="@(Model.Entidad != null)" />
                <input type="submit"
                       value="Guardar"
                       class="btn btn-secondary"
                       asp-page-handler="BtGuardar"
                       disabled="@(Model.Entidad == null)" />
            </div>

            @if (Model.Entidad != null)
            {
                <input type="hidden" asp-for="@Model.Entidad!.Id" />
                <input type="hidden" asp-for="@Model.Entidad!.Estado" />
                <input type="hidden" asp-for="@Model.Entidad!.Descuento" />
                <input type="hidden" asp-for="@Model.Entidad!.ValorSinDescuento" />

                <div>
                    <div class="form-group">
                        <label>Nombre</label>
                        <div class="col-6">
                            <input class="form-control" asp-for="@Model.Entidad!.Nombre" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Fecha</label>
                        <div class="col-6">
                            <input type="date" class="form-control"
                                   asp-for="@Model.Entidad!.Fecha"
                                   asp-format="{0:yyyy-MM-dd}" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Precio Entrada</label>
                        <div class="col-6">
                            <input type="number" step="0.01" class="form-control"
                                   asp-for="@Model.Entidad!.PrecioEntrada" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Jaula</label>
                        <div class="col-6">
                            <select class="form-control"
                                    asp-for="@Model.Entidad!.JaulaId"
                                    asp-items="Model.JaulasOpts">
                                <option value="">-- Seleccione --</option>
                            </select>
                        </div>
                    </div>
                    @if (Model.Entidad!.Id != 0)
                    {
                        <div class="form-group">
                            <label>Valor sin Descuento (calc)</label>
                            <div class="col-6">
                                <input class="form-control" value="@Model.Entidad!.ValorSinDescuento" readonly />
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Descuento (calc)</label>
                            <div class="col-6">
                                <input class="form-control" value="@Model.Entidad!.Descuento" readonly />
                            </div>
                        </div>
                    }
                </div>
            }

            @if (ViewData.ContainsKey("Mensaje"))
            {
                @await Html.PartialAsync("../Emergentes/Mensajes.cshtml");
            }

            @if (Model.Entidad != null && Model.Borrando)
            {
                <div class='popup'>
                    <div class='pp_ms_inner'>
                        <div style='width:95%'>
                            <h2 align="left">Mensaje</h2>
                            <h6 align="left">¿Desea borrar la entrada?</h6>
                            <h6 align="left">@Model.Entidad!.Nombre</h6>

                            <input type="submit"
                                   value="Cerrar"
                                   asp-page-handler="BtCerrar"
                                   class="btn btn-secondary" />
                            <input type="submit"
                                   value="Borrar"
                                   asp-page-handler="BtBorrar"
                                   class="btn btn-secondary" />
                        </div>
                    </div>
                </div>
            }

            @if (Model.Lista != null && Model.Lista.Count > 0)
            {
                <table class="tb_data table table-striped table-bordered table-hover">
                    <tr>
                        <th>Nombre</th>
                        <th>Fecha</th>
                        <th>Jaula</th>
                        <th>Precio</th>
                        <th>Valor s/Desc</th>
                        <th>Descuento</th>
                        <th>Total</th>
                        <th>Acción</th>
                    </tr>
                    @foreach (var e in Model.Lista)
                    {
                        var total = e.ValorSinDescuento * (1 - e.Descuento);
                        <tr>
                            <td>@e.Nombre</td>
                            <td>@e.Fecha.ToString("yyyy-MM-dd")</td>
                            <td>@(e.Jaula?.Nombre ?? "?")</td>
                            <td>@e.PrecioEntrada.ToString("0.00")</td>
                            <td>@e.ValorSinDescuento.ToString("0.00")</td>
                            <td>@(e.Descuento.ToString("0.00"))</td>
                            <td>@total.ToString("0.00")</td>
                            <td>
                                <input type="submit"
                                       value="Modificar"
                                       asp-page-handler="BtModificar"
                                       class="btn btn-secondary"
                                       asp-route-data="@e.Id" />
                                <input type="submit"
                                       value="Borrar"
                                       asp-page-handler="BtBorrarVal"
                                       class="btn btn-secondary"
                                       asp-route-data="@e.Id" />
                            </td>
                        </tr>
                    }
                </table>
            }
        </form>
    </div>
</center>
